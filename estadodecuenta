RUTA      = "/content"
PLANTILLA = os.path.join(RUTA, "formato_estadocuenta.xlsx")
INSUMO    = os.path.join(RUTA, "Historico de Pagos 2020_JUNIO 02.xlsx")
SALIDA    = os.path.join(RUTA, "Estado_de_Cuenta_Generado.xlsx")

# Mapeo exacto de columnas del histórico
COL_CDP_EXTERNO  = 'CDP Externo'                  # BB → I (col 9) en formato
COL_CRP_EXTERNO  = 'CRP Externo'                  # BC → J (col 10) en formato
COL_FECHA_INICIO = 'FECHA INICIAL DE CONTRATO'    # BE → D8
COL_FECHA_FIN    = 'FECHA DE TERMINACION FINAL'   # BF → H8
COL_VALOR_CTO    = 'VALOR FINAL DEL CONTRATO'     # BD → D7


def limpiar(dato):
    d = str(dato).split('.')[0]
    return "" if d in ("nan", "None", "NaT") else d


def build_merge_map(ws):
    """Devuelve dict {(row, col): (top_row, left_col)} para cada celda fusionada."""
    mmap = {}
    for mr in ws.merged_cells.ranges:
        min_col, min_row, max_col, max_row = range_boundaries(mr.coord)
        for r in range(min_row, max_row + 1):
            for c in range(min_col, max_col + 1):
                mmap[(r, c)] = (min_row, min_col)
    return mmap


def escribir_rc(ws, row, col, valor, fmt_moneda=False, mmap=None):
    """Escribe en (row, col) resolviendo celdas fusionadas."""
    if mmap is None:
        mmap = build_merge_map(ws)
    dest = mmap.get((row, col), (row, col))
    celda = ws.cell(row=dest[0], column=dest[1])
    celda.value = valor
    if fmt_moneda:
        celda.number_format = '"$"#,##0'


def escribir_coord(ws, coord, valor, fmt_moneda=False, mmap=None):
    """Escribe en una coordenada tipo 'D5' resolviendo fusiones."""
    col_letra = ''.join(filter(str.isalpha, coord))
    fila_num  = int(''.join(filter(str.isdigit, coord)))
    escribir_rc(ws, fila_num, column_index_from_string(col_letra),
                valor, fmt_moneda, mmap)


def desmerge_fila_datos(ws, fila, col_ini=2, col_fin=10):
    """Elimina fusiones que crucen la fila de datos (cols B-J)."""
    rangos_a_eliminar = []
    for mr in list(ws.merged_cells.ranges):
        min_col, min_row, max_col, max_row = range_boundaries(mr.coord)
        # Si la fusión toca esta fila Y está dentro de las columnas de datos
        if min_row <= fila <= max_row and min_col <= col_fin and max_col >= col_ini:
            rangos_a_eliminar.append(mr.coord)
    for coord in rangos_a_eliminar:
        ws.unmerge_cells(coord)


def generar_estado_cuenta(contrato_buscado):
    print(f"⚙️  Procesando compromiso: {contrato_buscado}")

    try:
        df = pd.read_excel(INSUMO)
        df.columns = df.columns.str.strip()
    except Exception as e:
        print(f"❌ Error leyendo histórico: {e}")
        return

    pagos = df[df['Referencia'].astype(str).str.contains(contrato_buscado, na=False)].copy()
    if pagos.empty:
        print(f"❌ No se encontró información para: {contrato_buscado}")
        return
    print(f"✅ {len(pagos)} pago(s) encontrado(s).")

    wb = openpyxl.load_workbook(PLANTILLA)
    ws = wb.active
    primer = pagos.iloc[0]

    # Desmerge preventivo en todas las filas de datos que se van a usar
    fila_inicio = 17
    fila_fin    = fila_inicio + len(pagos) - 1
    for f in range(fila_inicio, fila_fin + 1):
        desmerge_fila_datos(ws, f)

    # Reconstruir mapa de fusiones después del desmerge
    mmap = build_merge_map(ws)

    # ── ENCABEZADO ───────────────────────────────────────────────
    val_contrato = primer.get(COL_VALOR_CTO, 0) or 0

    escribir_coord(ws, 'D5', contrato_buscado, mmap=mmap)
    escribir_coord(ws, 'D6', str(primer.get('Nombre', '')), mmap=mmap)
    escribir_coord(ws, 'D7', val_contrato, fmt_moneda=True, mmap=mmap)
    escribir_coord(ws, 'D8', primer.get(COL_FECHA_INICIO, ''), mmap=mmap)   # BE
    escribir_coord(ws, 'H5', limpiar(primer.get('Proveedor', '')), mmap=mmap)
    escribir_coord(ws, 'H6', limpiar(primer.get('Nº identificación', '')), mmap=mmap)
    escribir_coord(ws, 'H7', limpiar(primer.get('Numero RP', '')), mmap=mmap)
    escribir_coord(ws, 'H8', primer.get(COL_FECHA_FIN, ''), mmap=mmap)      # BF

    # ── TABLA DE PAGOS ───────────────────────────────────────────
    fila_actual     = fila_inicio
    saldo_acumulado = val_contrato

    for i, (_, fila) in enumerate(pagos.iterrows(), start=1):
        monto = fila.get('Valor Bruto', 0) or 0
        saldo_acumulado -= monto

        escribir_rc(ws, fila_actual, 2,  i,                                        mmap=mmap)  # B: No.
        escribir_rc(ws, fila_actual, 3,  fila.get('Texto cabecera documento', ''), mmap=mmap)  # C: Periodo
        escribir_rc(ws, fila_actual, 4,  monto,           fmt_moneda=True,         mmap=mmap)  # D: Valor
        escribir_rc(ws, fila_actual, 5,  saldo_acumulado, fmt_moneda=True,         mmap=mmap)  # E: Saldo RP
        escribir_rc(ws, fila_actual, 6,  limpiar(fila.get('Doc.compensación', '')),mmap=mmap)  # F: No. Documento
        escribir_rc(ws, fila_actual, 7,  fila.get('Fecha de pago', ''),            mmap=mmap)  # G: Fecha
        escribir_rc(ws, fila_actual, 8,  limpiar(fila.get('Numero RP', '')),       mmap=mmap)  # H: RP SAP
        escribir_rc(ws, fila_actual, 9,  limpiar(fila.get(COL_CDP_EXTERNO, '')),   mmap=mmap)  # I: CDP  ← BB
        escribir_rc(ws, fila_actual, 10, limpiar(fila.get(COL_CRP_EXTERNO, '')),   mmap=mmap)  # J: RP   ← BC

        fila_actual += 1

    wb.save(SALIDA)
    print(f"✅ ¡PROCESO COMPLETADO!  →  {os.path.basename(SALIDA)}")

    # En Colab descomentar:
    # files.download(SALIDA)


# --- EJECUCIÓN ---
generar_estado_cuenta("130-2025")



